{
  "uid": "bvr-platform-ops",
  "title": "BVR Nexus — Platform Operations",
  "tags": ["bvr", "operations"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "BVR API",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "up{job=\"bvr-api\"}", "legendFormat": "API" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "AI Gateway",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "up{job=\"ai-gateway\"}", "legendFormat": "Gateway" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Redis",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "up{job=\"redis-exporter\"}", "legendFormat": "Redis" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Kestra",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "up{job=\"kestra\"}", "legendFormat": "Kestra" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "OPA",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "up{job=\"opa\"}", "legendFormat": "OPA" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "API Request Rate (req/s)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"bvr-api\"}[1m])",
          "legendFormat": "{{method}} {{path}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "API Response Latency (p95)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"bvr-api\"}[5m]))",
          "legendFormat": "p95 latency"
        },
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=\"bvr-api\"}[5m]))",
          "legendFormat": "p50 latency"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 3 }] }
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Redis — Connected Clients",
      "gridPos": { "x": 0, "y": 12, "w": 8, "h": 7 },
      "targets": [{ "expr": "redis_connected_clients", "legendFormat": "clients" }],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 5 } } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Redis — Memory Used",
      "gridPos": { "x": 8, "y": 12, "w": 8, "h": 7 },
      "targets": [{ "expr": "redis_memory_used_bytes", "legendFormat": "used" }],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 5 } } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Redis — Commands/s",
      "gridPos": { "x": 16, "y": 12, "w": 8, "h": 7 },
      "targets": [{ "expr": "rate(redis_commands_processed_total[1m])", "legendFormat": "cmd/s" }],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 5 } } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "HTTP Errors (5xx) — BVR API",
      "gridPos": { "x": 0, "y": 19, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"bvr-api\", status=~\"5..\"}[1m])",
          "legendFormat": "{{status}} {{path}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "fixedColor": "red", "mode": "fixed" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 0.01 }] }
        }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "HTTP Errors (5xx) — AI Gateway",
      "gridPos": { "x": 12, "y": 19, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"ai-gateway\", status=~\"5..\"}[1m])",
          "legendFormat": "{{status}} {{path}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "fixedColor": "orange", "mode": "fixed" }
        }
      }
    }
  ]
}
