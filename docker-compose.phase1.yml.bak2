version: "3.8"

# BVR NEXUS v2 — Revised Implementation
# Principles:
#   • Kestra orchestrates only
#   • BVR API + Workers handle business logic
#   • PostgreSQL + pgvector for everything data
#   • Redis for cache + lightweight messaging
#   • Traefik only (no Kong overlap)
#   • No Weaviate, ClickHouse, Kafka

services:
  # ───────────────────────────────────────────
  # L4. DATA & STATE LAYER (Simplified)
  # ───────────────────────────────────────────
  postgres:
    image: pgvector/pgvector:pg16-v0.7.0
    container_name: bvr-postgres
    env_file:
      - .env
    environment:
      POSTGRES_USER: ${POSTGRES_USER:-bvr}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-changeme}
      POSTGRES_DB: ${POSTGRES_DB:-bvr_nexus}
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ./api/init.sql:/docker-entrypoint-initdb.d/init.sql:ro
    ports:
      - "5432:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U bvr -d bvr_nexus"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - bvr-network

  redis:
    image: redis:7.2.4-alpine
    container_name: bvr-redis
    # NO PORT BINDING — internal Docker network only
    volumes:
      - redis_data:/data
    command: redis-server --appendonly yes
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - bvr-network

  minio:
    image: minio/minio:latest
    container_name: bvr-minio
    command: server /data --console-address ":9001"
    env_file:
      - .env
    environment:
      MINIO_ROOT_USER: ${MINIO_ROOT_USER:-bvradmin}
      MINIO_ROOT_PASSWORD: ${MINIO_ROOT_PASSWORD:-changeme}
    ports:
      - "9000:9000"
      - "9001:9001"
    volumes:
      - minio_data:/data
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:9000/minio/health/live"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - bvr-network

  minio-init:
    image: minio/mc:latest
    container_name: bvr-minio-init
    depends_on:
      minio:
        condition: service_healthy
    entrypoint: >
      /bin/sh -c "
      mc alias set local http://minio:9000 bvradmin bvrsecret123;
      mc mb local/bvr-artifacts --ignore-existing;
      mc mb local/bvr-logs --ignore-existing;
      mc policy set public local/bvr-artifacts;
      echo 'MinIO initialized.'
      "
    networks:
      - bvr-network

  # ───────────────────────────────────────────
  # L1. ORCHESTRATION LAYER (Kestra — Orchestration Only)
  # ───────────────────────────────────────────
  kestra:
    image: kestra/kestra:v0.18.0
    container_name: bvr-kestra
    pull_policy: always
    user: "root"
    command: server standalone
    env_file:
      - .env
    environment:
      KESTRA_CONFIGURATION: |
        datasources:
          postgres:
            url: jdbc:postgresql://postgres:5432/bvr_nexus
            driverClassName: org.postgresql.Driver
            username: ${POSTGRES_USER:-bvr}
            password: ${POSTGRES_PASSWORD:-changeme}
        kestra:
          repository:
            type: postgres
          queue:
            type: postgres
          storage:
            type: minio
            minio:
              endpoint: http://minio:9000
              accessKey: bvradmin
              secretKey: bvrsecret123
              bucket: bvr-artifacts
              region: us-east-1
          url: http://localhost:8080/
          server:
            basic-auth:
              enabled: false
    ports:
      - "8080:8080"
    depends_on:
      postgres:
        condition: service_healthy
      minio:
        condition: service_healthy
      redis:
        condition: service_healthy
    volumes:
      # Docker socket REMOVED for security (was: /var/run/docker.sock:/var/run/docker.sock)
      - kestra_data:/app/storage
      - ./kestra-workflows:/local-flows:ro
    networks:
      - bvr-network

  # ───────────────────────────────────────────
  # L0/L1. FASTAPI GATEWAY (BVR Application Layer)
  # ───────────────────────────────────────────
  bvr-api:
    build:
      context: .
      dockerfile: api/Dockerfile
    container_name: bvr-api
    environment:
      DATABASE_URL: postgresql+asyncpg://bvr:bvrsecret@postgres:5432/bvr_nexus
      REDIS_URL: redis://redis:6379
      MINIO_ENDPOINT: http://minio:9000
      MINIO_ACCESS_KEY: bvradmin
      MINIO_SECRET_KEY: bvrsecret123
      OPA_URL: http://opa:8181
      VAULT_URL: http://vault:8200
      VAULT_TOKEN: bvr-root-token
      KESTRA_URL: http://kestra:8080
      AI_GATEWAY_URL: http://ai-gateway:8000
    ports:
      - "8000:8000"
    volumes:
      - ./contracts:/app/contracts:ro
      - ./plugins:/app/plugins:ro
    depends_on:
      - postgres
      - redis
      - minio
    networks:
      - bvr-network

  # ───────────────────────────────────────────
  # AI GATEWAY (BVR-Specific)
  # ───────────────────────────────────────────
  ai-gateway:
    build:
      context: .
      dockerfile: ai-gateway/Dockerfile
    container_name: bvr-ai-gateway
    environment:
      ANTHROPIC_API_KEY: ${ANTHROPIC_API_KEY:-}
      OPENAI_API_KEY: ${OPENAI_API_KEY:-}
      KIMI_API_KEY: ${KIMI_API_KEY:-}
      OLLAMA_URL: http://ollama:11434
      REDIS_URL: redis://redis:6379
      DATABASE_URL: postgresql+asyncpg://bvr:bvrsecret@postgres:5432/bvr_nexus
    ports:
      - "8001:8000"
    depends_on:
      - postgres
      - redis
      - ollama
    networks:
      - bvr-network

  # ───────────────────────────────────────────
  # BVR WORKERS (Business Logic)
  # ───────────────────────────────────────────
  bvr-workers:
    build:
      context: .
      dockerfile: workers/Dockerfile
    container_name: bvr-workers
    environment:
      BVR_API_URL: http://bvr-api:8000
      REDIS_URL: redis://redis:6379
      DATABASE_URL: postgresql+asyncpg://bvr:bvrsecret@postgres:5432/bvr_nexus
      MINIO_ENDPOINT: http://minio:9000
      MINIO_ACCESS_KEY: bvradmin
      MINIO_SECRET_KEY: bvrsecret123
      AI_GATEWAY_URL: http://ai-gateway:8000
      OPA_URL: http://opa:8181
    volumes:
      - ./plugins:/app/plugins:ro
    depends_on:
      bvr-api:
        condition: service_started
      redis:
        condition: service_healthy
      postgres:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8080/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s
    deploy:
      resources:
        limits:
          cpus: '2.0'
          memory: 2G
        reservations:
          cpus: '0.5'
          memory: 512M
    networks:
      - bvr-network

  # ───────────────────────────────────────────
  # L3. AI / LLM (Local + Gateway)
  # ───────────────────────────────────────────
  ollama:
    image: ollama/ollama:0.1.48
    container_name: bvr-ollama
    ports:
      - "11434:11434"
    volumes:
      - ollama_data:/root/.ollama
    entrypoint: >
      /bin/sh -c "
      ollama serve &
      sleep 5;
      ollama pull llama3.3 || true;
      wait
      "
    networks:
      - bvr-network

  # ───────────────────────────────────────────
  # L5. GOVERNANCE LAYER
  # ───────────────────────────────────────────
  opa:
    image: openpolicyagent/opa:0.65.0
    container_name: bvr-opa
    command: run --server --addr :8181 --log-level info /policies
    # NO PORT BINDING — internal Docker network only
    volumes:
      - ./governance/rego:/policies:ro
    networks:
      - bvr-network

  vault:
    image: hashicorp/vault:1.17.0
    container_name: bvr-vault
    cap_add:
      - IPC_LOCK
    env_file:
      - .env
    environment:
      # PRODUCTION MODE — requires manual init/unseal via scripts/setup_vault.sh
      VAULT_ADDR: http://0.0.0.0:8200
    command: server -config=/vault/config/vault.hcl
    volumes:
      - vault_data:/vault/file
      - ./scripts/vault.hcl:/vault/config/vault.hcl:ro
    networks:
      - bvr-network

  keycloak:
    image: quay.io/keycloak/keycloak:25.0.1
    container_name: bvr-keycloak
    command: start-dev
    env_file:
      - .env
    environment:
      KC_DB: postgres
      KC_DB_URL: jdbc:postgresql://postgres:5432/bvr_nexus
      KC_DB_USERNAME: ${POSTGRES_USER:-bvr}
      KC_DB_PASSWORD: ${POSTGRES_PASSWORD:-changeme}
      KC_BOOTSTRAP_ADMIN_USERNAME: admin
      KC_BOOTSTRAP_ADMIN_PASSWORD: ${KEYCLOAK_ADMIN_PASSWORD:-changeme}
      KEYCLOAK_ADMIN: admin
      KEYCLOAK_ADMIN_PASSWORD: ${KEYCLOAK_ADMIN_PASSWORD:-changeme}
    ports:
      - "8081:8080"
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - bvr-network

  # ───────────────────────────────────────────
  # L6. OBSERVABILITY LAYER
  # ───────────────────────────────────────────
  prometheus:
    image: prom/prometheus:v2.53.0
    container_name: bvr-prometheus
    command:
      - '--config.file=/etc/prometheus/prometheus.yml'
      - '--storage.tsdb.path=/prometheus'
    ports:
      - "9090:9090"
    volumes:
      - ./observability/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - prometheus_data:/prometheus
    networks:
      - bvr-network

  grafana:
    image: grafana/grafana:11.0.0
    container_name: bvr-grafana
    environment:
      GF_SECURITY_ADMIN_USER: admin
      GF_SECURITY_ADMIN_PASSWORD: admin
      GF_INSTALL_PLUGINS: grafana-clock-panel,grafana-simple-json-datasource
    ports:
      - "3000:3000"
    volumes:
      - grafana_data:/var/lib/grafana
      - ./observability/dashboards:/etc/grafana/provisioning/dashboards:ro
    depends_on:
      - prometheus
    networks:
      - bvr-network

  jaeger:
    image: jaegertracing/all-in-one:1.58.0
    container_name: bvr-jaeger
    ports:
      - "16686:16686"
      - "4317:4317"
    networks:
      - bvr-network

  loki:
    image: grafana/loki:3.0.0
    container_name: bvr-loki
    ports:
      - "3100:3100"
    volumes:
      - ./observability/loki-config.yml:/etc/loki/local-config.yaml:ro
    command: -config.file=/etc/loki/local-config.yaml
    networks:
      - bvr-network

  # ───────────────────────────────────────────
  # L0. INGRESS (Traefik Only — No Kong Overlap)
  # ───────────────────────────────────────────
  traefik:
    image: traefik:v3.1.0
    container_name: bvr-traefik
    command:
      - "--api.insecure=true"
      - "--providers.docker=true"
      - "--providers.docker.exposedbydefault=false"
      - "--entrypoints.web.address=:80"
      - "--entrypoints.websecure.address=:443"
      - "--ping=true"
    ports:
      - "80:80"
      - "443:443"
      - "8082:8080"  # Traefik dashboard
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - ./gateway/traefik.yml:/etc/traefik/traefik.yml:ro
    networks:
      - bvr-network

volumes:
  postgres_data:
  redis_data:
  minio_data:
  kestra_data:
  ollama_data:
  vault_data:
  prometheus_data:
  grafana_data:

networks:
  bvr-network:
    driver: bridge
