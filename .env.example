# BVR Nexus Environment Configuration
# ⚠️  CRITICAL: DO NOT COMMIT THIS FILE TO VERSION CONTROL
#
# Copy to .env and populate before starting any stack:
#   cp .env.example .env && make secrets
#
# Generate strong passwords with one of these methods:
#   openssl rand -base64 32
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#   make secrets
#
# The start.sh script auto-generates values marked GENERATE.

# ──────────────────────────────────────
# DATABASE
# ──────────────────────────────────────
POSTGRES_USER=bvr
POSTGRES_PASSWORD=GENERATE
POSTGRES_DB=bvr_nexus

# ──────────────────────────────────────
# CACHE / EVENT BUS (Redis)
# ──────────────────────────────────────
REDIS_PASSWORD=GENERATE

# ──────────────────────────────────────
# OBJECT STORAGE (MinIO)
# ──────────────────────────────────────
MINIO_ROOT_USER=bvradmin
MINIO_ROOT_PASSWORD=GENERATE
# SSE-S3 encryption key — format: <key-name>:<base64-32-byte-key>
# Generate: python3 -c "import secrets,base64; print('bvr-master:'+base64.b64encode(secrets.token_bytes(32)).decode())"
MINIO_KMS_SECRET_KEY=GENERATE

# ──────────────────────────────────────
# ORCHESTRATION (Kestra)
# Required in production (basic-auth enabled)
# ──────────────────────────────────────
KESTRA_ADMIN_USERNAME=admin
KESTRA_ADMIN_PASSWORD=GENERATE

# ──────────────────────────────────────
# SECRET MANAGEMENT (Vault)
# Production: set VAULT_TOKEN after running vault init + vault unseal
# start.sh generates a placeholder; replace with the real token after:
#   bash scripts/setup_vault.sh
# ──────────────────────────────────────
VAULT_TOKEN=GENERATE

# ──────────────────────────────────────
# IDENTITY (Keycloak)
# ──────────────────────────────────────
KEYCLOAK_ADMIN_PASSWORD=GENERATE

# ──────────────────────────────────────
# OBSERVABILITY (Grafana)
# ──────────────────────────────────────
GF_ADMIN_PASSWORD=GENERATE

# ──────────────────────────────────────
# INGRESS (Traefik dashboard)
# ──────────────────────────────────────
# htpasswd format — generate with:
#   htpasswd -nb admin yourpassword | sed 's/\$/\$\$/g'
# The sed step escapes $ for docker-compose env var interpolation.
TRAEFIK_DASHBOARD_USERS=GENERATE

# ──────────────────────────────────────
# SERVICE AUTH
# ──────────────────────────────────────
BVR_SERVICE_TOKEN=GENERATE

# ──────────────────────────────────────
# API CONFIGURATION
# ──────────────────────────────────────
# Comma-separated list of allowed CORS origins
API_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8082

# ──────────────────────────────────────
# EXTERNAL API KEYS (fill in real values)
# ──────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=your-openai-key-here
KIMI_API_KEY=your-kimi-key-here
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
GITHUB_TOKEN=ghp-your-github-token-here

# ──────────────────────────────────────
# TLS / ACME (Let's Encrypt via Traefik)
# Email used for certificate expiry notifications.
# Not a secret — but kept here for consistency.
# ──────────────────────────────────────
ACME_EMAIL=admin@bvrinfra.in

# ──────────────────────────────────────
# MONITORING ACCESS CONTROL
# htpasswd credentials for Prometheus, Loki, Jaeger (via Traefik BasicAuth).
# Generate: htpasswd -nb admin <your-password>
# Example:  admin:$apr1$xyz$hashedpassword
# ──────────────────────────────────────
MONITORING_BASIC_AUTH_USERS=admin:GENERATE
