# BVR Nexus Environment Configuration
# ⚠️  CRITICAL: DO NOT COMMIT THIS FILE TO VERSION CONTROL
#
# Copy to .env and populate before starting any stack:
#   cp .env.example .env && make secrets
#
# Generate strong passwords with one of these methods:
#   openssl rand -base64 32
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#   make secrets
#
# The start.sh script auto-generates values marked GENERATE.

# ──────────────────────────────────────
# DATABASE
# ──────────────────────────────────────
POSTGRES_USER=bvr
POSTGRES_PASSWORD=GENERATE
POSTGRES_DB=bvr_nexus

# ──────────────────────────────────────
# OBJECT STORAGE (MinIO)
# ──────────────────────────────────────
MINIO_ROOT_USER=bvradmin
MINIO_ROOT_PASSWORD=GENERATE

# ──────────────────────────────────────
# ORCHESTRATION (Kestra)
# Required in production (basic-auth enabled)
# ──────────────────────────────────────
KESTRA_ADMIN_USERNAME=admin
KESTRA_ADMIN_PASSWORD=GENERATE

# ──────────────────────────────────────
# SECRET MANAGEMENT (Vault)
# Production: set VAULT_TOKEN after running vault init + vault unseal
# Development: VAULT_DEV_ROOT_TOKEN_ID is used by Vault dev mode
# ──────────────────────────────────────
VAULT_TOKEN=GENERATE
VAULT_DEV_ROOT_TOKEN_ID=GENERATE

# ──────────────────────────────────────
# IDENTITY (Keycloak)
# ──────────────────────────────────────
KEYCLOAK_ADMIN_PASSWORD=GENERATE

# ──────────────────────────────────────
# OBSERVABILITY (Grafana)
# ──────────────────────────────────────
GF_ADMIN_PASSWORD=GENERATE

# ──────────────────────────────────────
# SERVICE AUTH
# ──────────────────────────────────────
BVR_SERVICE_TOKEN=GENERATE

# ──────────────────────────────────────
# EXTERNAL API KEYS (fill in real values)
# ──────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=your-openai-key-here
KIMI_API_KEY=your-kimi-key-here
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
GITHUB_TOKEN=ghp-your-github-token-here
