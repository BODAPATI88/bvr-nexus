# BVR Nexus Environment Configuration
# ⚠️  CRITICAL: DO NOT COMMIT THIS FILE TO VERSION CONTROL
#
# Generate strong passwords with one of these methods:
#   openssl rand -base64 32
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#   make secrets
#
# The start.sh script will auto-generate these if left as "GENERATE"

# PostgreSQL
POSTGRES_USER=bvr
POSTGRES_PASSWORD=GENERATE
POSTGRES_DB=bvr_nexus

# MinIO
MINIO_ROOT_USER=bvradmin
MINIO_ROOT_PASSWORD=GENERATE

# Kestra (uses same PostgreSQL)
KESTRA_DB_PASSWORD=GENERATE

# Vault
VAULT_DEV_ROOT_TOKEN_ID=GENERATE

# Keycloak
KEYCLOAK_ADMIN_PASSWORD=GENERATE

# BVR Service Token (for service-to-service auth)
BVR_SERVICE_TOKEN=GENERATE

# External API Keys (fill in your real keys)
ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=your-openai-key-here
KIMI_API_KEY=your-kimi-key-here
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
GITHUB_TOKEN=ghp-your-github-token-here
